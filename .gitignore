# Rust build artifacts
target/
debug/
release/
*.rs.bk
*.rlib
*.prof*

# NOTE: Cargo.lock and pnpm-lock.yaml are intentionally COMMITTED — Smoothie's pitch
# is reproducibility, so builds must be pinned (CI runs `cargo test --locked` and
# `pnpm install --frozen-lockfile`).

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# macOS
.DS_Store

# Node / TypeScript (frontend + schema packages)
node_modules/
dist/
*.tsbuildinfo

# Model credentials - Pi/Codex OAuth tokens (ChatGPT subscription). NEVER commit.
auth.json
.pi/

# Provisioned Python env for the describe agent (recreated by `uv` on demand)
.smoothie-pyenv/

# Environment
.env
.env.*
*.log

# Local design docs/specs - kept on disk, out of git history. Anchored to the repo
# root so nested dirs (e.g. frontend/src/toolkit/docs) are NOT swept up.
/docs/
/specs/
/specs_/

# Local content drafts (blog posts, announcements) - kept on disk, out of git.
/content/

# other
.snek/
.claude/
claude-sessions-backup/

