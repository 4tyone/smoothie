{
  "name": "smoothie",
  "version": "0.2.0",
  "description": "Smoothie — the TS compiler frontend (on Pi): ingest → describe → structure → link → resolve → compile. Bundles the svm runtime (ADR-0001).",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "bin": {
    "smoothie": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "compile:fake": "tsx src/cli.ts compile"
  },
  "dependencies": {
    "@smoothie/schema": "workspace:*",
    "@earendil-works/pi-ai": "^0.80.2",
    "valibot": "^1.0.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.7.0"
  }
}
