{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smoothie.dev/schema/bc.v1.schema.json",
  "title": "bc.v1",
  "description": "The Smoothie BC contract (spec 02). Single source of truth: the TS frontend validates on write, the Rust SVM mirrors this with serde and validates on read. Breaking format changes bump bc.v2.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "manifest"],
  "properties": {
    "schema": { "const": "bc.v1" },
    "manifest": { "$ref": "#/$defs/Manifest" },
    "brief": { "$ref": "#/$defs/Brief" },
    "sources": { "type": "object", "additionalProperties": { "$ref": "#/$defs/Source" } },
    "facts": { "type": "object", "additionalProperties": { "$ref": "#/$defs/Fact" } },
    "graph": { "$ref": "#/$defs/Graph" },
    "views": { "type": "object", "additionalProperties": { "$ref": "#/$defs/View" } },
    "outlines": { "type": "object", "additionalProperties": { "$ref": "#/$defs/Outline" } },
    "glossary": { "type": "object", "additionalProperties": { "$ref": "#/$defs/GlossaryEntry" } },
    "notes": { "type": "object", "additionalProperties": { "$ref": "#/$defs/Note" } },
    "cache": { "type": "object" },
    "policy": { "$ref": "#/$defs/Policy" },
    "extensions": {
      "type": "object",
      "description": "Namespaced add-ons; keys must be reverse-DNS, e.g. com.smoothie.reader.video.",
      "propertyNames": { "pattern": "\\." }
    }
  },
  "$defs": {
    "Fidelity": { "enum": ["confirmed", "claimed", "guessed", "absent"] },

    "Manifest": {
      "type": "object",
      "required": ["bc_id", "profile", "producer", "created_at", "updated_at", "counts"],
      "properties": {
        "bc_id": { "type": "string" },
        "profile": { "type": "string", "description": "target profile, e.g. web-app | codebase | corpus" },
        "app": {
          "type": "object",
          "description": "web-app profile only",
          "properties": {
            "name": { "type": "string" },
            "app_ref": { "type": "string" },
            "base_url": { "type": "string" },
            "allowed_origins": { "type": "array", "items": { "type": "string" } }
          }
        },
        "producer": {
          "type": "object",
          "required": ["name", "version"],
          "properties": {
            "name": { "type": "string" },
            "version": { "type": "string" },
            "commit": { "type": "string" }
          }
        },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" },
        "counts": {
          "type": "object",
          "required": ["sources", "facts", "nodes", "edges", "views", "outlines"],
          "properties": {
            "sources": { "type": "integer", "minimum": 0 },
            "facts": { "type": "integer", "minimum": 0 },
            "nodes": { "type": "integer", "minimum": 0 },
            "edges": { "type": "integer", "minimum": 0 },
            "views": { "type": "integer", "minimum": 0 },
            "outlines": { "type": "integer", "minimum": 0 }
          }
        },
        "authorship": {
          "type": "object",
          "properties": {
            "author": { "type": "string" },
            "organization": { "type": "string" },
            "signature": { "type": "string" }
          }
        }
      }
    },

    "Brief": {
      "type": "object",
      "required": ["brief_id", "text", "created_at"],
      "properties": {
        "brief_id": { "type": "string" },
        "text": { "type": "string" },
        "goals": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "text"],
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" },
              "done_when": { "type": "string" }
            }
          }
        },
        "scope": {
          "type": "object",
          "properties": {
            "include": { "type": "array", "items": { "type": "string" } },
            "exclude": { "type": "array", "items": { "type": "string" } }
          }
        },
        "created_at": { "type": "string" }
      }
    },

    "Source": {
      "type": "object",
      "required": ["source_id", "kind"],
      "properties": {
        "source_id": { "type": "string" },
        "kind": { "type": "string", "description": "Reader modality tag (spec 04)" },
        "path": { "type": "string" },
        "uri": { "type": "string" },
        "hash": { "type": "string" },
        "title": { "type": "string" },
        "media_type": { "type": "string" },
        "companions": { "type": "array", "items": { "$ref": "#/$defs/Companion" } },
        "metadata": { "type": "object" }
      }
    },

    "Companion": {
      "type": "object",
      "required": ["kind", "path"],
      "properties": {
        "kind": { "enum": ["transcript", "frame", "screenshot", "dom", "ax", "audio", "other"] },
        "path": { "type": "string" },
        "hash": { "type": "string" },
        "source_span": { "$ref": "#/$defs/SourceSpan" }
      }
    },

    "Fact": {
      "type": "object",
      "required": ["fact_id", "kind", "text", "confidence", "fidelity", "source_refs"],
      "properties": {
        "fact_id": { "type": "string" },
        "kind": { "enum": ["knowledge", "action"] },
        "text": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "view_id": { "type": "string" },
        "fidelity": { "$ref": "#/$defs/Fidelity" },
        "source_refs": { "type": "array", "items": { "$ref": "#/$defs/SourceRef" } },
        "brief_id": { "type": "string" },
        "action_draft": {
          "type": "object",
          "required": ["verb", "target"],
          "properties": {
            "verb": { "enum": ["goto", "click", "fill", "select", "press", "scroll", "wait_for", "unknown"] },
            "target": { "type": "string" },
            "value_hint": { "type": "string" },
            "locator_hint": { "type": "string" },
            "expected_effect": { "type": "string" }
          }
        }
      }
    },

    "Graph": {
      "type": "object",
      "properties": {
        "nodes": { "type": "object", "additionalProperties": { "$ref": "#/$defs/Node" } },
        "edges": { "type": "array", "items": { "$ref": "#/$defs/Edge" } },
        "roots": { "type": "array", "items": { "type": "string" } }
      }
    },

    "Node": {
      "type": "object",
      "required": ["id", "title", "summary", "kind", "fidelity", "source_refs"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "summary": { "type": ["string", "null"] },
        "kind": { "type": "string", "description": "profile vocabulary (web-app: screen|feature|flow|action)" },
        "view_id": { "type": "string" },
        "fact_ids": { "type": "array", "items": { "type": "string" } },
        "action": { "$ref": "#/$defs/Action" },
        "checks": { "type": "array", "items": { "$ref": "#/$defs/Check" } },
        "done_when": { "type": "string" },
        "fidelity": { "$ref": "#/$defs/Fidelity" },
        "source_refs": { "type": "array", "items": { "$ref": "#/$defs/SourceRef" } },
        "notice": { "type": "string", "description": "confidentiality (spec 06 §2): a caution surfaced on every read of this node" },
        "restricted": { "type": "boolean", "description": "read restriction (spec 06 §2): the SVM withholds content on read unless authorized (--reveal); enforced in code" }
      }
    },

    "Edge": {
      "type": "object",
      "required": ["from", "to", "kind", "fidelity", "source_refs"],
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" },
        "kind": { "enum": ["contains", "transition", "enables", "depends_on", "next", "related_to"] },
        "label": { "type": "string" },
        "fidelity": { "$ref": "#/$defs/Fidelity" },
        "source_refs": { "type": "array", "items": { "$ref": "#/$defs/SourceRef" } }
      }
    },

    "Action": {
      "type": "object",
      "required": ["kind"],
      "oneOf": [
        { "properties": { "kind": { "const": "goto" }, "url": { "type": "string" } }, "required": ["url"] },
        { "properties": { "kind": { "const": "click" }, "locator": { "$ref": "#/$defs/Locator" } }, "required": ["locator"] },
        { "properties": { "kind": { "const": "fill" }, "locator": { "$ref": "#/$defs/Locator" }, "value": { "type": "string" } }, "required": ["locator", "value"] },
        { "properties": { "kind": { "const": "select" }, "locator": { "$ref": "#/$defs/Locator" }, "value": { "type": "string" } }, "required": ["locator", "value"] },
        { "properties": { "kind": { "const": "press" }, "key": { "type": "string" } }, "required": ["key"] },
        { "properties": { "kind": { "const": "scroll" }, "locator": { "$ref": "#/$defs/Locator" }, "to": { "enum": ["element", "top", "bottom"] } } },
        { "properties": { "kind": { "const": "wait_for" }, "locator": { "$ref": "#/$defs/Locator" }, "condition": { "type": "string" } } }
      ]
    },

    "Locator": {
      "type": "object",
      "required": ["description", "primary"],
      "properties": {
        "description": { "type": "string" },
        "primary": { "$ref": "#/$defs/LocatorStrategy" },
        "fallbacks": { "type": "array", "items": { "$ref": "#/$defs/LocatorStrategy" } }
      }
    },

    "LocatorStrategy": {
      "type": "object",
      "required": ["by", "value"],
      "properties": {
        "by": { "enum": ["role", "testid", "label", "text", "css"] },
        "value": { "type": "string" },
        "name": { "type": "string" }
      }
    },

    "Check": {
      "type": "object",
      "required": ["kind"],
      "oneOf": [
        { "properties": { "kind": { "const": "visible" }, "locator": { "$ref": "#/$defs/Locator" } }, "required": ["locator"] },
        { "properties": { "kind": { "const": "exists" }, "locator": { "$ref": "#/$defs/Locator" } }, "required": ["locator"] },
        { "properties": { "kind": { "const": "text_matches" }, "locator": { "$ref": "#/$defs/Locator" }, "expected": { "type": "string" } }, "required": ["expected"] },
        { "properties": { "kind": { "const": "url_matches" }, "expected": { "type": "string" } }, "required": ["expected"] }
      ]
    },

    "View": {
      "type": "object",
      "required": ["view_id", "title", "fidelity"],
      "properties": {
        "view_id": { "type": "string" },
        "title": { "type": "string" },
        "url_patterns": { "type": "array", "items": { "type": "string" } },
        "node_ids": { "type": "array", "items": { "type": "string" } },
        "fidelity": { "$ref": "#/$defs/Fidelity" },
        "observations": { "type": "array", "items": { "$ref": "#/$defs/Observation" } },
        "aliases": { "type": "array", "items": { "type": "string" } }
      }
    },

    "Observation": {
      "type": "object",
      "required": ["observation_id", "source_ref", "url", "captured_at", "mode"],
      "properties": {
        "observation_id": { "type": "string" },
        "source_ref": { "$ref": "#/$defs/SourceRef" },
        "url": { "type": "string" },
        "captured_at": { "type": "string" },
        "mode": { "enum": ["read-only", "dry-run", "live"] },
        "ax_snapshot": { "type": "string" },
        "dom_snapshot": { "type": "string" },
        "screenshot": { "type": "string" }
      }
    },

    "Outline": {
      "type": "object",
      "required": ["outline_id", "brief_id", "title", "fidelity"],
      "properties": {
        "outline_id": { "type": "string" },
        "brief_id": { "type": "string" },
        "title": { "type": "string" },
        "scenes": { "type": "array", "items": { "$ref": "#/$defs/Scene" } },
        "fidelity": { "$ref": "#/$defs/Fidelity" }
      }
    },

    "Scene": {
      "type": "object",
      "required": ["scene_id", "title", "fidelity"],
      "properties": {
        "scene_id": { "type": "string" },
        "title": { "type": "string" },
        "node_ids": { "type": "array", "items": { "type": "string" } },
        "done_when": { "type": "string" },
        "fidelity": { "$ref": "#/$defs/Fidelity" },
        "gaps": { "type": "array", "items": { "type": "string" } }
      }
    },

    "SourceRef": {
      "type": "object",
      "required": ["source_id", "span"],
      "properties": {
        "source_id": { "type": "string" },
        "span": { "$ref": "#/$defs/SourceSpan" }
      }
    },

    "SourceSpan": {
      "type": "object",
      "required": ["kind"],
      "oneOf": [
        { "properties": { "kind": { "const": "time" }, "t_start": { "type": "number" }, "t_end": { "type": "number" } }, "required": ["t_start", "t_end"] },
        { "properties": { "kind": { "const": "doc" }, "page": { "type": "integer" }, "section": { "type": "string" }, "lines": { "type": "array", "items": { "type": "integer" }, "minItems": 2, "maxItems": 2 }, "label": { "type": "string" } } },
        { "properties": { "kind": { "const": "crawl" }, "page_id": { "type": "string" }, "url": { "type": "string" } }, "required": ["page_id"] },
        { "properties": { "kind": { "const": "live" }, "note": { "type": "string" } }, "required": ["note"] },
        { "properties": { "kind": { "const": "resolve" }, "resolver": { "type": "string" }, "ref": { "type": "string" }, "note": { "type": "string" } }, "required": ["resolver", "ref"] }
      ]
    },

    "GlossaryEntry": {
      "type": "object",
      "required": ["definition"],
      "properties": {
        "definition": { "type": "string" },
        "references": { "type": "array", "items": { "type": "string" } }
      }
    },

    "Note": {
      "type": "object",
      "required": ["text"],
      "properties": {
        "text": { "type": "string" },
        "kind": { "type": "string", "description": "for gap:* notes: knowledge | action" },
        "refs": { "type": "array", "items": { "$ref": "#/$defs/SourceRef" } }
      }
    },

    "Policy": {
      "type": "object",
      "description": "Execution policy (web-app profile); empty for non-executable profiles (spec 06).",
      "properties": {
        "scope": {
          "type": "object",
          "properties": {
            "allowed_origins": { "type": "array", "items": { "type": "string" } },
            "url_denylist": { "type": "array", "items": { "type": "string" } },
            "same_origin_only": { "type": "boolean" }
          }
        },
        "actions": {
          "type": "object",
          "properties": {
            "blocklist_verbs": { "type": "array", "items": { "type": "string" } },
            "allow_irreversible": { "type": "boolean" },
            "allow_form_submit": { "type": "boolean" },
            "allow_rules": { "type": "array", "items": { "type": "object", "required": ["match", "reason"], "properties": { "match": { "type": "string" }, "reason": { "type": "string" } } } },
            "danger": { "type": "array", "items": { "type": "object", "required": ["match", "level", "reason"], "properties": { "match": { "type": "string" }, "level": { "enum": ["block", "approve", "supervise"] }, "reason": { "type": "string" } } } }
          }
        },
        "budget": {
          "type": "object",
          "properties": {
            "max_actions": { "type": "integer" },
            "max_pages": { "type": "integer" },
            "max_depth": { "type": "integer" },
            "max_cost": { "type": "number" },
            "max_seconds": { "type": "integer" }
          }
        },
        "approval": {
          "type": "object",
          "required": ["require_for", "handler"],
          "properties": {
            "require_for": { "enum": ["none", "irreversible", "all-mutations"] },
            "handler": { "enum": ["interactive", "policy-only"] }
          }
        },
        "secrets": {
          "type": "object",
          "properties": { "redact_patterns": { "type": "array", "items": { "type": "string" } } }
        }
      }
    }
  }
}
